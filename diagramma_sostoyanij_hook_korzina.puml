@startuml diagramma_sostoyanij_hook_korzina
' Диаграмма состояний: перехват удаления libtrashhook.so (trash_hook.c)
' plantuml -tpng -charset UTF-8 diagramma_sostoyanij_hook_korzina.puml

skinparam shadowing false
skinparam linetype ortho
skinparam defaultFontName DejaVu Sans
skinparam state {
  BackgroundColor #E3F2FD
  BorderColor #1565C0
  FontSize 11
}
skinparam state<<choice>> {
  BackgroundColor #FFF9C4
  BorderColor #F9A825
  FontShape diamond
}
skinparam state<<op>> {
  BackgroundColor #E8F5E9
  BorderColor #2E7D32
}
skinparam state<<fb>> {
  BackgroundColor #FFEBEE
  BorderColor #C62828
}
skinparam state<<ok>> {
  BackgroundColor #E8F5E9
  BorderColor #1B5E20
}

title Диаграмма состояний\n«Корзина» — перехват unlink (libtrashhook.so, trash_hook.c)

left to right direction

[*] --> Waiting

state "Ожидание вызова\nunlink / unlinkat / remove" as Waiting

state h1 <<choice>>
state h2 <<choice>>
state h3 <<choice>>
state h4 <<choice>>
state h5 <<choice>>
state h6 <<choice>>
state h7 <<choice>>
state h8 <<choice>>

state "Инициализация символов libc\n(pthread_once, dlsym)" as OpInit <<op>>
state "Операции переноса\nв корзину" as OpTrash <<op>>
state "Обычное удаление\n(call_real_unlink)" as OpReal <<fb>>
state "Ошибка перехвата\n(return -1)" as OpErr <<fb>>
state "Файл в корзине\n(return 0)" as OpOk <<ok>>

state join <<join>>

Waiting --> OpInit
OpInit --> h1

h1 --> OpReal : [Обход перехвата:\nin_hook или TRASH_HOOK_DISABLE]\n[Удаление без корзины]
h1 --> h2 : [иначе]

h2 --> OpReal : [Абсолютный путь\nне получен]
h2 --> h3 : [иначе]

h3 --> OpErr : [lstat неуспешен]
h3 --> h4 : [иначе]

h4 --> OpErr : [Объект — каталог]
h4 --> h5 : [иначе]

h5 --> OpReal : [Путь вне $HOME]
h5 --> OpTrash : [Файл в домашнем\nкаталоге]

state h9 <<choice>>
state h10 <<choice>>

OpTrash --> h6

h6 --> h9 : [rename в Trash/files\nуспешен]
h6 --> h7 : [иначе]

h7 --> OpReal : [errno != EXDEV]
h7 --> h8 : [EXDEV: копирование\nи реальный unlink]

h8 --> OpReal : [Перенос не выполнен]
h8 --> h9 : [иначе]

h9 --> OpErr : [trash_write_info\nнеуспешна]
h9 --> OpOk : [Метаданные записаны]

OpReal --> join
OpErr --> join
OpOk --> join

join --> [*] : [Завершение обработки вызова]

@enduml
