    if (snprintf(info_dir, info_sz, "%s/%s", trash_root, TRASH_INFO_DIR) >= (int)info_sz) {
        errno = ENAMETOOLONG;
        return -1;
    }
    return 0;
}

int trash_ensure_layout(void) {
