int trash_url_encode_path(const char *src, char *dst, size_t dst_sz) {
    static const char hex[] = "0123456789ABCDEF";
    size_t si = 0;
    size_t di = 0;

    if (!src || !dst || dst_sz == 0) {
        errno = EINVAL;
        return -1;
    }

    while (src[si] != '\0') {
        unsigned char c = (unsigned char)src[si];
        int safe = isalnum(c) || c == '/' || c == '-' || c == '_' || c == '.' || c == '~';
        if (safe) {
            if (di + 1 >= dst_sz) {
                errno = ENAMETOOLONG;
                return -1;
            }
            dst[di++] = (char)c;
        } else {
            if (di + 3 >= dst_sz) {
                errno = ENAMETOOLONG;
                return -1;
            }
            dst[di++] = '%';
            dst[di++] = hex[(c >> 4) & 0x0F];
            dst[di++] = hex[c & 0x0F];
        }
        si++;
    }
    dst[di] = '\0';
    return 0;
}

static int hex_value(char c) {
    if (c >= '0' && c <= '9') {
        return c - '0';
    }
    if (c >= 'a' && c <= 'f') {
        return 10 + (c - 'a');
    }
    if (c >= 'A' && c <= 'F') {
        return 10 + (c - 'A');
    }
    return -1;
}

int trash_url_decode_path(const char *src, char *dst, size_t dst_sz) {
    size_t si = 0;
    size_t di = 0;

    if (!src || !dst || dst_sz == 0) {
        errno = EINVAL;
        return -1;
    }

    while (src[si] != '\0') {
        if (di + 1 >= dst_sz) {
            errno = ENAMETOOLONG;
            return -1;
        }

        if (src[si] == '%' && src[si + 1] != '\0' && src[si + 2] != '\0') {
            int hi = hex_value(src[si + 1]);
            int lo = hex_value(src[si + 2]);
            if (hi >= 0 && lo >= 0) {
                dst[di++] = (char)((hi << 4) | lo);
                si += 3;
                continue;
            }
        }

        dst[di++] = src[si++];
    }

    dst[di] = '\0';
    return 0;
}

int trash_now_iso8601(char *dst, size_t dst_sz) {
