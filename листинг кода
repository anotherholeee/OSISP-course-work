        return -1;
    }

    if (localtime_r(&now, &tm_buf) == NULL) {
        return -1;
    }

    if (strftime(dst, dst_sz, "%Y-%m-%dT%H:%M:%S", &tm_buf) == 0) {
        errno = ENAMETOOLONG;
        return -1;
    }
    return 0;
}

int trash_generate_id(const char *path, char *dst, size_t dst_sz) {
